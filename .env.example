# Copy to .env and fill in. .env is gitignored.

# Postgres connection string (Azure Database for PostgreSQL Flexible Server).
# Local example: postgresql://postgres:postgres@localhost:5432/laferiacr?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/laferiacr?sslmode=require"

# Read-path data source: "db" reads markets from Postgres; anything else (or unset)
# falls back to the bundled static list (src/data/ferias.json) for v0 parity.
DATA_SOURCE="static"

# Azure Maps — the detail-page map authenticates via a server-minted Entra ID token
# (src/app/api/maps/token), never a shared key. Set the Maps account's unique client id;
# when unset the map degrades gracefully to an "unavailable" note.
AZURE_MAPS_CLIENT_ID=""
# In Azure, the user-assigned managed identity client id so DefaultAzureCredential picks
# the right identity. Leave empty locally (falls back to `az login`).
AZURE_MANAGED_IDENTITY_CLIENT_ID=""

# --- Auth.js (NextAuth v5) + Microsoft Entra External ID (CIAM) ---
# Sign-in is optional in Phase 2; leave these empty to run without auth (the
# "Sign in" button will error until configured). See docs/decisions/0011 and the
# operator runbook in deploy/entra-external-id-setup.md.
#
# Random 32+ byte secret used to encrypt the session JWT. Generate: `npx auth secret`.
AUTH_SECRET=""
# App registration (client) id from the Entra External ID tenant.
AUTH_MICROSOFT_ENTRA_ID_ID=""
# Client secret value for that app registration (store in Key Vault in Azure).
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
# CIAM authority, e.g. https://<subdomain>.ciamlogin.com/<tenant-id>/v2.0
AUTH_MICROSOFT_ENTRA_ID_ISSUER=""

# --- Phase 3: community contributions (propose → confirm → verify) ---
# Net confirmations (confirm − reject) required to auto-promote a proposal to the
# market's verified value. Operator-tunable (Super-Admin-configurable in Phase 4);
# defaults to 2 when unset. See docs/architecture/moderation-trust.md.
CONFIRMATION_THRESHOLD="2"

# Anti-abuse CAPTCHA on anonymous writes. Off on dev until provider keys exist; the
# server verifies fail-closed when enabled. See ADR-0012. Provider seam: Cloudflare
# Turnstile is the first adapter. When enabling, also expose the site key to the client.
CAPTCHA_ENABLED="false"
CAPTCHA_PROVIDER="turnstile"
CAPTCHA_SECRET=""
NEXT_PUBLIC_CAPTCHA_SITE_KEY=""

# Break-glass super_admin bootstrap (ADR-0013). Set to the operator's Entra `oid`
# (preferred) or sign-in email; `npm run db:seed:admin` grants that user the
# super_admin role in `user_roles`. Leave empty to skip.
SUPER_ADMIN_OID=""
SUPER_ADMIN_EMAIL=""
