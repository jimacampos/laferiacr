// Prisma schema for La Feria CR — Phase 1 (backend foundation).
// Storage: PostgreSQL Flexible Server + PostGIS (see docs/architecture/data-model.md,
// docs/decisions/0004-database-postgresql-flexible.md, docs/decisions/0010-orm-prisma.md).
//
// Prisma 7 uses the `prisma-client` generator (TypeScript output) and a driver adapter
// (@prisma/adapter-pg). The connection string is supplied at runtime via the adapter and
// to the CLI via prisma.config.ts.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Canonical record per feria (farmer's market). Seeded from the official June 2026 list
/// with source='official'; community contributions land in later phases via proposals.
model Market {
  id         String   @id @default(uuid()) @db.Uuid
  /// Stable seed key (the v0 slug id); drives idempotent upserts.
  slug       String   @unique
  name       String
  regionId   String   @map("region_id")
  regionName String   @map("region_name")
  /// Canonical day-of-week keys in week order, e.g. ["fri","sat"].
  days       Json
  /// Original Spanish day label from the source list.
  daysLabel  String   @map("days_label")
  /// Human-readable operating hours; null until contributed (Phase 3).
  hoursText  String?  @map("hours_text")
  /// Market administrator/organizer.
  organizer  String?
  phones     String[] @default([])
  /// PostGIS point; null until a location is known/contributed (Phase 3).
  location   Unsupported("geography(Point, 4326)")?
  /// Provenance: 'official' (seed list) | 'community' (added later).
  source     String   @default("official")
  /// 'active' | 'hidden' | 'pending'.
  status     String   @default("active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  proposals     Proposal[]
  changeHistory ChangeHistory[]

  @@index([regionId])
  @@map("markets")
}

/// Application account, created on first sign-in via Microsoft Entra External ID
/// (see docs/decisions/0005-identity-entra-external-id.md). Maps the IdP subject to an
/// internal record; holds minimal PII (see docs/architecture/security-privacy.md).
/// Roles/permissions land in Phase 4 (user_roles), not here.
model User {
  id          String   @id @default(uuid()) @db.Uuid
  /// Stable IdP subject (OIDC `sub`) — unique per account.
  externalId  String   @unique @map("external_id")
  email       String?
  displayName String?  @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  proposals     Proposal[]
  confirmations Confirmation[]
  roles         UserRole[]

  @@map("users")
}

/// A suggested change to ONE field of a market (Phase 3 contribution loop; see
/// docs/architecture/data-model.md, docs/architecture/moderation-trust.md, ADR-0007/0008).
/// Anonymous proposals are allowed (`submittedBy` null); an account is required to confirm.
model Proposal {
  id        String @id @default(uuid()) @db.Uuid
  marketId  String @map("market_id") @db.Uuid
  /// 'hours' | 'location'.
  field     String
  /// JSON payload: a string for hours; { "lat": number, "lng": number } for location.
  proposedValue Json @map("proposed_value")
  /// Author account; null for anonymous submissions (ADR-0007).
  submittedBy String? @map("submitted_by") @db.Uuid
  /// Hashed submitter IP for abuse triage only (operational, short-retention).
  submitterIpHash String? @map("submitter_ip_hash")
  /// 'pending' | 'verified' | 'superseded' | 'rejected'.
  status    String @default("pending")
  /// Cached vote tallies; net = confirmCount - rejectCount drives promotion at N.
  confirmCount Int @default(0) @map("confirm_count")
  rejectCount  Int @default(0) @map("reject_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  market        Market         @relation(fields: [marketId], references: [id], onDelete: Cascade)
  submitter     User?          @relation(fields: [submittedBy], references: [id], onDelete: SetNull)
  confirmations Confirmation[]
  changeHistory ChangeHistory[]

  @@index([marketId, field, status])
  @@index([submittedBy])
  @@map("proposals")
}

/// One account-gated vote on a proposal. Unique per (proposal, user) → one vote each.
/// A proposal's own author cannot confirm it (enforced in the API).
model Confirmation {
  id         String @id @default(uuid()) @db.Uuid
  proposalId String @map("proposal_id") @db.Uuid
  userId     String @map("user_id") @db.Uuid
  /// 'confirm' | 'reject'.
  vote       String
  createdAt  DateTime @default(now()) @map("created_at")

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([proposalId, userId])
  @@map("confirmations")
}

/// Flag on a market or proposal (polymorphic target). Anonymous reports allowed.
/// Feeds the Phase 4 moderation queue; Phase 3 only records them.
model Report {
  id         String @id @default(uuid()) @db.Uuid
  /// 'market' | 'proposal'.
  targetType String @map("target_type")
  targetId   String @map("target_id") @db.Uuid
  /// Reporter account; null for anonymous reports.
  reportedBy String? @map("reported_by") @db.Uuid
  reason     String?
  /// 'open' | 'actioned' | 'dismissed'.
  status     String @default("open")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([targetType, targetId, status])
  @@index([status, createdAt])
  @@map("reports")
}

/// Append-only record of every promoted field change and every break-glass admin action —
/// enables display of history and revert (NFR-11). `causedByProposal` set for automated
/// promotions; `actorId` set for admin override/revert/hide.
model ChangeHistory {
  id               String  @id @default(uuid()) @db.Uuid
  marketId         String  @map("market_id") @db.Uuid
  field            String
  oldValue         Json?   @map("old_value")
  newValue         Json?   @map("new_value")
  causedByProposal String? @map("caused_by_proposal") @db.Uuid
  /// Admin who performed a manual action; null for automated promotions.
  actorId          String? @map("actor_id") @db.Uuid
  /// 'promote' | 'override' | 'revert' | 'hide'.
  action           String  @default("promote")
  createdAt        DateTime @default(now()) @map("created_at")

  market   Market    @relation(fields: [marketId], references: [id], onDelete: Cascade)
  proposal Proposal? @relation(fields: [causedByProposal], references: [id], onDelete: SetNull)

  @@index([marketId, field])
  @@map("change_history")
}

/// Grants a role to a user (pulled forward from Phase 4 for minimal break-glass admin;
/// see docs/architecture/rbac.md). Phase 3 only uses 'super_admin'.
model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  /// 'member' | 'trusted' | 'community_safety' | 'super_admin'.
  role      String
  /// Optional scope (e.g. region) for future regional moderators.
  scope     String?
  grantedAt DateTime @default(now()) @map("granted_at")
  /// Granting admin; null when bootstrapped/seeded.
  grantedBy String?  @map("granted_by") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role, scope])
  @@map("user_roles")
}

/// Durable per-IP log of anonymous write attempts, counted within a trailing window for
/// rate limiting (see ADR-0012). Operational data with short retention; pruned periodically.
model ContributionAttempt {
  id        String   @id @default(uuid()) @db.Uuid
  ipHash    String   @map("ip_hash")
  /// 'proposal' | 'report'.
  action    String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([ipHash, action, createdAt])
  @@map("contribution_attempts")
}

/// Append-only audit of moderator/admin actions (Phase 4, ADR-0014) — who did what to which
/// target and why. Complements `change_history`, which logs field value diffs used for revert;
/// this table captures the governance action itself (removals, hides, bans, role and config
/// changes). FKs to `users` are enforced in SQL (see migration) rather than as Prisma relations,
/// mirroring the Phase 3 `reports`/`change_history` precedent to keep the `User` model clean.
model ModerationAction {
  id         String   @id @default(uuid()) @db.Uuid
  /// Moderator/admin who performed the action; null if the account was later deleted.
  actorId    String?  @map("actor_id") @db.Uuid
  /// e.g. 'resolve_report' | 'dismiss_report' | 'remove_proposal' | 'hide_market' |
  /// 'unhide_market' | 'override_field' | 'revert_field' | 'grant_role' | 'revoke_role' |
  /// 'ban_user' | 'lift_ban' | 'set_config'.
  action     String
  /// 'market' | 'proposal' | 'report' | 'user' | 'config'.
  targetType String   @map("target_type")
  /// Target uuid where applicable; null for keyed targets (e.g. a config key kept in metadata).
  targetId   String?  @map("target_id") @db.Uuid
  reason     String?
  /// Extra structured context (role granted, ban duration, config key + old/new value, etc.).
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([targetType, targetId])
  @@index([actorId])
  @@index([createdAt])
  @@map("moderation_actions")
}

/// Temporary or permanent ban on a user (Phase 4, ADR-0014). An active ban blocks all writes
/// (propose / confirm-reject / report). Active = `lifted_at IS NULL AND (expires_at IS NULL OR
/// expires_at > now())`; a null `expires_at` is a permanent ban. FKs enforced in SQL.
model UserBan {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  reason    String?
  /// Moderator/admin who issued the ban; null if that account was later deleted.
  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  /// When the ban expires; null = permanent.
  expiresAt DateTime? @map("expires_at")
  /// When the ban was lifted early; null = still active (subject to expiry).
  liftedAt  DateTime? @map("lifted_at")
  liftedBy  String?   @map("lifted_by") @db.Uuid

  @@index([userId, expiresAt])
  @@map("user_bans")
}

/// Admin-configurable key/value settings (Phase 4, ADR-0015). Currently holds
/// `confirmation_threshold` (N). Runtime read order: this table → env → built-in default,
/// so the app still runs unconfigured on dev.
model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  /// Super Admin who last changed the value; null when seeded.
  updatedBy String?  @map("updated_by") @db.Uuid

  @@map("app_config")
}
